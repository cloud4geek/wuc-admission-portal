{
  "apps": [
    {
      "name": "wuc-backend",
      "script": "server.js",
      "cwd": "/home/ubuntu/wuc-admission-portal/backend",
      "instances": 1,
      "exec_mode": "cluster",
      "env": {
        "NODE_ENV": "production",
        "PORT": 5000
      },
      "log_file": "/home/ubuntu/logs/wuc-backend.log",
      "error_file": "/home/ubuntu/logs/wuc-backend-error.log",
      "out_file": "/home/ubuntu/logs/wuc-backend-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "merge_logs": true,
      "max_memory_restart": "1G",
      "restart_delay": 4000,
      "autorestart": true,
      "watch": false
    }
  ]
}